lastNews&q;:[{&q;title&q;:&q;أزمة حزب الله بين السلاح والعقيدة&q;,&q;sub_title&q;:null,&q;url&q;:&q;أزمة-حزب-الله-بين-السلاح-والعقيدة&q;,&q;excerpt&q;:&q;مشكلة \&q;حزب الله\&q; بالنسبة الى كثيرين من اللبنانيين ليست بامتلاكه السلاح فحسب، بل بالقرار الذي يتحكّم بهذا السلاح، وبالعقيدة الفكرية والسياسية المرتبطة بالمشروع الإيراني. فالمسألة لم تعد مرتبطة بمواجهة إسرائيل أو بمفهوم المقاومة فحسب، بل بثقافة كاملة قائمة على فكرة \&q;الثورة الدائمة\&q; والعداء المستمر للغرب ولعدد كبير من الأنظمة السياسية والثقافات المختلفة، عبر شعاراتٍ مثل \&q;الموت لأميركا\&q; والتعامل مع كثير من مفاهيم الحداثة والانفتاح كأنها تهديد عقائدي أو أخلاقي.&q;,&q;category&q;:{&q;id&q;:4,&q;name&q;:&q;مقالات مختارة&q;,&q;color&q;:&q;#fc5242&q;,&q;url&q;:&q;مقالات-مختارة&q;},&q;gallery&q;:[],&q;video_type&q;:null,&q;uploaded_video&q;:null,&q;embedded_video&q;:null,&q;classifications&q;:[],&q;author&q;:{&q;id&q;:5006,&q;name&q;:&q;طارق عزت دندش&q;,&q;url&q;:&q;طارق-عزت-دندش&q;},&q;source&q;:{&q;id&q;:3,&q;name&q;:&q;النهار&q;,&q;color&q;:null,&q;url&q;:&q;النهار&q;},&q;tags&q;:[{&q;id&q;:204,&q;name&q;:&q;حزب الله&q;,&q;url&q;:&q;حزب-الله&q;},{&q;id&q;:199,&q;name&q;:&q;ايران&q;,&q;url&q;:&q;ايران&q;},{&q;id&q;:264,&q;name&q;:&q;سلاح حزب الله&q;,&q;url&q;:&q;سلاح-حزب-الله&q;}],&q;date&q;:&q;2026-05-18 11:21:50&q;,&q;featured_images&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/hezbolla/hezeb-mounaser.jpg&q;,&q;sort_order&q;:0}]},{&q;title&q;:&q;جبران ليس سوريّاً… حين يُزوَّر تاريخ لبنان في قلب نيويورك&q;,&q;sub_title&q;:null,&q;url&q;:&q;جبران-ليس-سوريا-حين-يزور-تاريخ-لبنان-في-قلب-نيويورك&q;,&q;excerpt&q;:&q;في لحظةٍ كان يُفترض أن تكون احتفالاً بتراث المهاجرين اللبنانيين والعرب في الولايات المتحدة، تحوّل النصب التذكاري الخاص بالرابطة القلمية في نيويورك إلى مادة غضب واعتراض ثقافي وتاريخي واسع، بعدما جرى تقديم عدد من أعظم أدباء المهجر، وفي مقدّمهم جبران خليل جبران وميخائيل نعيمه وإيليا أبو ماضي وأمين الريحاني وعفيفة كرم، على أنهم “سوريون”، في مشهد اعتبره مؤرخون ومثقفون لبنانيون تزويراً مباشراً للهوية الثقافية اللبنانية ومحاولة جديدة لابتلاع ذاكرة لبنان ورموزه الحضارية.&q;,&q;category&q;:{&q;id&q;:4,&q;name&q;:&q;مقالات مختارة&q;,&q;color&q;:&q;#fc5242&q;,&q;url&q;:&q;مقالات-مختارة&q;},&q;gallery&q;:[],&q;video_type&q;:null,&q;uploaded_video&q;:null,&q;embedded_video&q;:null,&q;classifications&q;:[],&q;author&q;:null,&q;source&q;:{&q;id&q;:2,&q;name&q;:&q;Kataeb.org&q;,&q;color&q;:null,&q;url&q;:&q;kataeb.org&q;},&q;tags&q;:[{&q;id&q;:1805,&q;name&q;:&q;نيويورك&q;,&q;url&q;:&q;نيويورك&q;},{&q;id&q;:504,&q;name&q;:&q;جبران خليل جبران&q;,&q;url&q;:&q;جبران-خليل-جبران&q;},{&q;id&q;:81,&q;name&q;:&q;سوريا&q;,&q;url&q;:&q;سوريا&q;}],&q;date&q;:&q;2026-05-18 08:18:08&q;,&q;featured_images&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/Figures/Gibran-Khalil-Gibran.jpg&q;,&q;sort_order&q;:0}]},{&q;title&q;:&q;أيار 1973 يوم كادت الدولة تفرض سلطتها على كامل التراب اللبناني&q;,&q;sub_title&q;:null,&q;url&q;:&q;أيار-1973-يوم-كادت-الدولة-تفرض-سلطتها-على-كامل-التراب-اللبناني&q;,&q;excerpt&q;:&q;على أثر اغتيال القادة الفلسطينيين في فردان، راحت البلاد، ولاسيما العاصمة، تشهد تجاوزات واسعة للمسلحين الفلسطينيين، بدأت قبل الغارة الإسرائيلية، وتوسعت في الأيام التي تلت جنازة القادة الفلسطينيين.&q;,&q;category&q;:{&q;id&q;:4,&q;name&q;:&q;مقالات مختارة&q;,&q;color&q;:&q;#fc5242&q;,&q;url&q;:&q;مقالات-مختارة&q;},&q;gallery&q;:[],&q;video_type&q;:null,&q;uploaded_video&q;:null,&q;embedded_video&q;:null,&q;classifications&q;:[],&q;author&q;:{&q;id&q;:309,&q;name&q;:&q;نبيل يوسف&q;,&q;url&q;:&q;نبيل-يوسف&q;},&q;source&q;:{&q;id&q;:239,&q;name&q;:&q;نداء الوطن&q;,&q;color&q;:null,&q;url&q;:&q;ندا-الوطن&q;},&q;tags&q;:[{&q;id&q;:16257,&q;name&q;:&q;الفصائل الفلسطينية&q;,&q;url&q;:&q;الفصائل-الفلسطينية&q;},{&q;id&q;:16196,&q;name&q;:&q;حزب الكتائب اللبنانية&q;,&q;url&q;:&q;حزب-الكتائب-اللبنانية&q;},{&q;id&q;:2045,&q;name&q;:&q;حزب الوطنيين الأحرار&q;,&q;url&q;:&q;حزب_الوطنيين_الأحرار&q;}],&q;date&q;:&q;2026-05-16 07:46:23&q;,&q;featured_images&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/Divers/ayyar 1973 Pierre Gemayel.jpg&q;,&q;sort_order&q;:0}]},{&q;title&q;:&q;بين \&q;أمل\&q; و\&q;الحزب\&q;… سقوط أسطورة \&q;الثنائي\&q;&q;,&q;sub_title&q;:null,&q;url&q;:&q;بين-أمل-والحزب-سقوط-أسطورة-الثنائي&q;,&q;excerpt&q;:&q;لم يعد ممكناً إخفاء التصدعات العميقة داخل ما يُعرف بـ”الثنائي الشيعي”. فالصورة التي طالما سُوّقت للبنانيين على أنها تحالف عضوي ثابت بين حركة “أمل” و”حz*ب ال*له”، بدأت تتفكك تحت ضغط الحرب، والانهيار الاقتصادي، وحجم الخسائر التي أصابت البيئة الشيعية نفسها قبل غيرها. ما يجري اليوم لم يعد مجرد اختلاف في الأسلوب أو تباين في التكتيك السياسي، بل تحوّل إلى أزمة ثقة حقيقية تتسلل إلى الشارع والبيوت ومراكز النزوح وحتى داخل الأطر التنظيمية الضيقة.&q;,&q;category&q;:{&q;id&q;:4,&q;name&q;:&q;مقالات مختارة&q;,&q;color&q;:&q;#fc5242&q;,&q;url&q;:&q;مقالات-مختارة&q;},&q;gallery&q;:[],&q;video_type&q;:null,&q;uploaded_video&q;:null,&q;embedded_video&q;:null,&q;classifications&q;:[],&q;author&q;:{&q;id&q;:4972,&q;name&q;:&q;فرنسوا الجردي&q;,&q;url&q;:&q;فرنسوا-الجردي&q;},&q;source&q;:{&q;id&q;:3184,&q;name&q;:&q;beirut times&q;,&q;color&q;:null,&q;url&q;:&q;beirut-times&q;},&q;tags&q;:[{&q;id&q;:3550,&q;name&q;:&q;الثنائي الشيعي&q;,&q;url&q;:&q;الثنائي_الشيعي&q;},{&q;id&q;:1225,&q;name&q;:&q;حركة أمل&q;,&q;url&q;:&q;حركة_أمل&q;},{&q;id&q;:204,&q;name&q;:&q;حزب الله&q;,&q;url&q;:&q;حزب-الله&q;}],&q;date&q;:&q;2026-05-14 20:47:25&q;,&q;featured_images&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/hezbolla/Flags-of-Amal-movement-and-Hezbollah.jpg&q;,&q;sort_order&q;:0}]},{&q;title&q;:&q;حين تتحوّل الدولة من مرجعية إلى رهينة&q;,&q;sub_title&q;:null,&q;url&q;:&q;حين-تتحول-الدولة-من-مرجعية-إلى-رهينة&q;,&q;excerpt&q;:&q;يقدَّم مقال نواف الموساوي المدافع عن بقاء السلاح خارج سلطة الدولة اللبنانية بوصفه خطاباً فلسفياً وسياسياً يعيد النظر في مفهوم \&q;احتكار الدولة للعنف المشروع\&q;. ويستند هذا الطرح ��لى مروحة واسعة من المراجع الفكرية، من Thomas Hobbes وMax Weber  إلى Karl Marx وFrantz Fanon، في محاولة لإضفاء شرعية فكرية على استمرار وجود تنظيم مسلّح خارج الدولة.&q;,&q;category&q;:{&q;id&q;:4,&q;name&q;:&q;مقالات مختارة&q;,&q;color&q;:&q;#fc5242&q;,&q;url&q;:&q;مقالات-مختارة&q;},&q;gallery&q;:[],&q;video_type&q;:null,&q;uploaded_video&q;:null,&q;embedded_video&q;:null,&q;classifications&q;:[{&q;id&q;:2,&q;name&q;:&q;مقالات مختارة&q;,&q;url&q;:&q;مقالات-مختارة&q;}],&q;author&q;:{&q;id&q;:87,&q;name&q;:&q;آلان حكيم&q;,&q;url&q;:&q;لان-حكيم&q;},&q;source&q;:{&q;id&q;:180,&q;name&q;:&q;المدن&q;,&q;color&q;:null,&q;url&q;:&q;المدن&q;},&q;tags&q;:[{&q;id&q;:3092,&q;name&q;:&q;السلاح&q;,&q;url&q;:&q;السلاح&q;},{&q;id&q;:1452,&q;name&q;:&q;الدولة اللبنانية&q;,&q;url&q;:&q;الدولة_اللبنانية&q;}],&q;date&q;:&q;2026-05-14 14:00:40&q;,&q;featured_images&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/Flag/lebanon flag126.jpg&q;,&q;sort_order&q;:0}]},{&q;title&q;:&q;الدولة ليست فكرة اختيارية… وحصرية السلاح ليست ترفًا سياسيًا&q;,&q;sub_title&q;:null,&q;url&q;:&q;الدولة-ليست-فكرة-اختيارية-وحصرية-السلاح-ليست-ترفا-سياسيا&q;,&q;excerpt&q;:&q;إنّ أخطر ما في المقال الذي كتبه أحد قادة \&q;حزب الله\&q; في جريدة الأخبار، والمعنون \&q;الدولة واحتكار الدفاع: نقد مفهوم حصرية السلاح\&q; ليس أنه يناقش مفهوم الدولة، فهذا حقّ مشروع في أي نقاش فكري، بل أنه يحاول، تحت غطاء الفلسفة السياسية، إعادة تعريف الدولة بما يسمح بتبرير قيام سلطة مسلّحة موازية لها، ثم تصوير هذا الخلل البنيوي وكأنه حالة دفاعية مشروعة.&q;,&q;category&q;:{&q;id&q;:4,&q;name&q;:&q;مقالات مختارة&q;,&q;color&q;:&q;#fc5242&q;,&q;url&q;:&q;مقالات-مختارة&q;},&q;gallery&q;:[],&q;video_type&q;:null,&q;uploaded_video&q;:null,&q;embedded_video&q;:null,&q;classifications&q;:[{&q;id&q;:2,&q;name&q;:&q;مقالات مختارة&q;,&q;url&q;:&q;مقالات-مختارة&q;}],&q;author&q;:{&q;id&q;:4058,&q;name&q;:&q;ريتا بولس&q;,&q;url&q;:&q;ريتا-بولس&q;},&q;source&q;:{&q;id&q;:239,&q;name&q;:&q;نداء الوطن&q;,&q;color&q;:null,&q;url&q;:&q;ندا-الوطن&q;},&q;tags&q;:[{&q;id&q;:204,&q;name&q;:&q;حزب الله&q;,&q;url&q;:&q;حزب-الله&q;},{&q;id&q;:21845,&q;name&q;:&q;حصر السلاح&q;,&q;url&q;:&q;حصر-السلاح-&q;}],&q;date&q;:&q;2026-05-14 07:55:59&q;,&q;featured_images&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/Flag/Lebanon FLAG263.jpg&q;,&q;sort_order&q;:0}]},{&q;title&q;:&q;الجنوب ركاماً: “الحزب” دمّر الجغرافيا ثمّ أنكرها&q;,&q;sub_title&q;:null,&q;url&q;:&q;الجنوب-ركاما-الحزب-دمر-الجغرافيا-ثم-أنكرها&q;,&q;excerpt&q;:&q;“لا حاجة إلى الثبات في الجغرافيا”، وأخيراً قالها الأمين العامّ لـ”الحزب”، الشيخ نعيم قاسم. قالها وأرغم الجنوبيّين عليها، فنقلهم من بيوتهم وقراهم وبلداتهم إلى اللاجغرافيا ولأجلٍ لا يعرفه إلّا هو و”الراسخون” خلفه ومعه. في المقابل، يتشكّل لدى النازحين والمهجّرين خطابٌ آخر، جوهره المطالبة بالعودة إلى الجغرافيا التي اقتُلعوا منها: قراهم، دساكرهم، وأبواب رزقهم.&q;,&q;category&q;:{&q;id&q;:4,&q;name&q;:&q;مقالات مختارة&q;,&q;color&q;:&q;#fc5242&q;,&q;url&q;:&q;مقالات-مختارة&q;},&q;gallery&q;:[],&q;video_type&q;:null,&q;uploaded_video&q;:null,&q;embedded_video&q;:null,&q;classifications&q;:[{&q;id&q;:2,&q;name&q;:&q;مقالات مختارة&q;,&q;url&q;:&q;مقالات-مختارة&q;}],&q;author&q;:{&q;id&q;:4348,&q;name&q;:&q;أيمن جزيني&q;,&q;url&q;:&q;أيمن-جزيني&q;},&q;source&q;:{&q;id&q;:2952,&q;name&q;:&q;أساس ميديا&q;,&q;color&q;:null,&q;url&q;:&q;أساس-ميديا&q;},&q;tags&q;:[{&q;id&q;:204,&q;name&q;:&q;حزب الله&q;,&q;url&q;:&q;حزب-الله&q;},{&q;id&q;:548,&q;name&q;:&q;ولاية الفقيه&q;,&q;url&q;:&q;ولاية-الفقيه&q;}],&q;date&q;:&q;2026-05-13 07:05:24&q;,&q;featured_images&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/aita-cha3eb-damar.jpeg&q;,&q;sort_order&q;:0}]},{&q;title&q;:&q;من القائمقاميتين إلى الطائف: لماذا يحتاج لبنان إلى دولة لا إلى فدرالية؟&q;,&q;sub_title&q;:null,&q;url&q;:&q;من-القائمقاميتين-إلى-الطائف-لماذا-يحتاج-لبنان-إلى-دولة-لا-إلى-فدرالية&q;,&q;excerpt&q;:&q;في النقاش اللبناني الدائر اليوم حول مستقبل النظام السياسي، تعود إلى الواجهة بقوة دعواتٌ إلى إعادة النظر في الصيغة الدستورية القائمة، بل إلى الانتقال نحو نظام فدرالي يُقدَّم أحياناً كعلاج جذري لأزمات الدولة المتراكمة. غير أن هذا الجدل، على أهميته، يفرض العودة إلى سؤال أعمق من مجرد المفاضلة بين نموذجين دستوريين: هل تكمن أزمة لبنان في شكل النظام، أم في غياب الدولة نفسها؟ وهل الفدرالية هي البديل المنطقي عن اتفاق الطائف، أم أن الدفاع عن الطائف—مع استكمال تطبيقه—هو الطريق الأقرب إلى إنقاذ الكيان اللبناني؟&q;,&q;category&q;:{&q;id&q;:4,&q;name&q;:&q;مقالات مختارة&q;,&q;color&q;:&q;#fc5242&q;,&q;url&q;:&q;مقالات-مختارة&q;},&q;gallery&q;:[],&q;video_type&q;:null,&q;uploaded_video&q;:null,&q;embedded_video&q;:null,&q;classifications&q;:[],&q;author&q;:{&q;id&q;:4890,&q;name&q;:&q;بطرس الخوري&q;,&q;url&q;:&q;بطرس-الخوري&q;},&q;source&q;:{&q;id&q;:239,&q;name&q;:&q;نداء الوطن&q;,&q;color&q;:null,&q;url&q;:&q;ندا-الوطن&q;},&q;tags&q;:[{&q;id&q;:538,&q;name&q;:&q;اتفاق الطائف&q;,&q;url&q;:&q;اتفاق-الطائف&q;},{&q;id&q;:2367,&q;name&q;:&q;الفدرالية&q;,&q;url&q;:&q;الفدرالية&q;},{&q;id&q;:2968,&q;name&q;:&q;الطائفية&q;,&q;url&q;:&q;الطائفية&q;}],&q;date&q;:&q;2026-05-11 10:49:04&q;,&q;featured_images&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/Lebanon/lebanon flag.jpeg&q;,&q;sort_order&q;:0}]}]},{&q;type&q;:&q;category&q;,&q;label&q;:null,&q;link&q;:null,&q;haveSubMenu&q;:true,&q;item&q;:{&q;id&q;:14,&q;name&q;:&q;دوليّات&q;,&q;url&q;:&q;دوليات&q;},&q;items&q;:[],&q;lastNews&q;:[{&q;title&q;:&q;بالصورة- ترامب برفقة مخلوق فضائي&q;,&q;sub_title&q;:null,&q;url&q;:&q;بالصورة-ترامب-برفقة-مخلوق-فضائي&q;,&q;excerpt&q;:&q;نشر الرئيس الأميركي دونالد ترامب صورة غريبة على حسابه على منصة “تروث سوشل” وهو يمشي برفقة مخلوق فضائي مكبل اليدين.&q;,&q;category&q;:{&q;id&q;:14,&q;name&q;:&q;دوليّات&q;,&q;color&q;:&q;#009999&q;,&q;url&q;:&q;دوليات&q;},&q;gallery&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/Photos/barad3i/tru1.jpg&q;,&q;sort_order&q;:0},{&q;id&q;:null,&q;image&q;:&q;new-website/Photos/barad3i/tru2.jpg&q;,&q;sort_order&q;:1},{&q;id&q;:null,&q;image&q;:&q;new-website/Photos/barad3i/tru3.jpg&q;,&q;sort_order&q;:2}],&q;video_type&q;:null,&q;uploaded_video&q;:null,&q;embedded_video&q;:null,&q;classifications&q;:[],&q;author&q;:null,&q;source&q;:{&q;id&q;:115,&q;name&q;:&q;Sky News&q;,&q;color&q;:null,&q;url&q;:&q;sky-news&q;},&q;tags&