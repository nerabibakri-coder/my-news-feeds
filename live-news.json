ations&q;:[],&q;author&q;:{&q;id&q;:4865,&q;name&q;:&q;جيل خوري&q;,&q;url&q;:&q;جيل-خوري&q;},&q;source&q;:{&q;id&q;:3144,&q;name&q;:&q;لوريان لوجور&q;,&q;color&q;:null,&q;url&q;:&q;لوريان-لوجور&q;},&q;tags&q;:[{&q;id&q;:23489,&q;name&q;:&q;بينالي البندقية&q;,&q;url&q;:&q;بينالي-البندقية&q;}],&q;date&q;:&q;2026-05-08 11:22:17&q;,&q;featured_images&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/Divers/Screenshot 2026-05-08 112135.png&q;,&q;sort_order&q;:0}]},{&q;title&q;:&q;بينالي البندقية بعيون عربية&q;,&q;sub_title&q;:null,&q;url&q;:&q;بينالي-البندقية-بعيون-عربية&q;,&q;excerpt&q;:&q;منذ تأسيسه عام 1895، تحوّل \&q;بينالي البندقية\&q; إلى مساحة تختبر فيها الدول والفنانون والمؤسسات الثقافية شكل العالم المعاصر وتوتراته وأسئلته الكبرى. ولهذا السبب، يوصف الحدث غالباً بأنّه \&q;أولمبياد الفن المعاصر\&q;، إذ يجمع، كل عامين، مئات الفنانين والقيّمين والنقّاد والمتاحف وصنّاع القرار الثقافي من مختلف أنحاء العالم.&q;,&q;category&q;:{&q;id&q;:78,&q;name&q;:&q;ثقافة وتراث&q;,&q;color&q;:&q;#53e4ee&q;,&q;url&q;:&q;ثقافة-وتراث&q;},&q;gallery&q;:[],&q;video_type&q;:null,&q;uploaded_video&q;:null,&q;embedded_video&q;:null,&q;classifications&q;:[],&q;author&q;:null,&q;source&q;:{&q;id&q;:3,&q;name&q;:&q;النهار&q;,&q;color&q;:null,&q;url&q;:&q;النهار&q;},&q;tags&q;:[{&q;id&q;:23489,&q;name&q;:&q;بينالي البندقية&q;,&q;url&q;:&q;بينالي-البندقية&q;}],&q;date&q;:&q;2026-05-08 10:53:41&q;,&q;featured_images&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/Divers/Screenshot 2026-05-08 104749.png&q;,&q;sort_order&q;:0}]},{&q;title&q;:&q;مسابقة ديانا أرسلان: دعم المواهب الطلابية لكتابة الرواية والقصة القصيرة&q;,&q;sub_title&q;:null,&q;url&q;:&q;مسابقة-ديانا-أرسلان-دعم-المواهب-الطلابية-لكتابة-الراوية-والقصة-القصيرة&q;,&q;excerpt&q;:&q;بدعوة من الاميرة حياة ارسلان وايمانا منها بمواهب الطلاب وتنميتها اقيمت مسابقة \&q;ديانا ارسلان\&q; لكتابة الرواية او القصة القصيرة وذلك بحضور النائب السابق مصباح الاحدب الذي أمن النقليات من طرابلس الى عاليه ورئيسة مكتب شؤون المرأة في اقليم زغرتا الزاوية الكتائبي المربي