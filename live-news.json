 وثقافية واجتماعية.&q;,&q;category&q;:{&q;id&q;:78,&q;name&q;:&q;ثقافة وتراث&q;,&q;color&q;:&q;#53e4ee&q;,&q;url&q;:&q;ثقافة-وتراث&q;},&q;gallery&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/Divers/Yousef Bek Karam zgharta.jpg&q;,&q;sort_order&q;:0},{&q;id&q;:null,&q;image&q;:&q;new-website/Divers/Yousef Bek Karam zgharta0.jpg&q;,&q;sort_order&q;:1},{&q;id&q;:null,&q;image&q;:&q;new-website/Divers/Yousef Bek Karam zgharta1.jpg&q;,&q;sort_order&q;:2},{&q;id&q;:null,&q;image&q;:&q;new-website/Divers/Yousef Bek Karam zgharta2.jpg&q;,&q;sort_order&q;:3}],&q;video_type&q;:null,&q;uploaded_video&q;:null,&q;embedded_video&q;:null,&q;classifications&q;:[],&q;author&q;:null,&q;source&q;:{&q;id&q;:2,&q;name&q;:&q;Kataeb.org&q;,&q;color&q;:null,&q;url&q;:&q;kataeb.org&q;},&q;tags&q;:[{&q;id&q;:2194,&q;name&q;:&q;زغرتا&q;,&q;url&q;:&q;زغرتا&q;},{&q;id&q;:20115,&q;name&q;:&q;يوسف بك كرم&q;,&q;url&q;:&q;-يوسف-بك-كرم-&q;}],&q;date&q;:&q;2026-04-26 11:10:14&q;,&q;featured_images&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/Divers/Yousef Bek Karam zgharta1.jpg&q;,&q;sort_order&q;:0}]},{&q;title&q;:&q;\&q;يوسف بك كرم والفكرة الوطنية اللبنانية بين التصور المشرقي والوعي الكياني في القرن التاسع عشر\&q;... كتاب للدكتور ابراهيم شاكر&q;,&q;sub_title&q;:null,&q;url&q;:&q;يوسف-بك-كرم-والفكرة-الوطنية-اللبنانية-بين-التصور-المشرقي-والوعي-الكياني-في-القرن-التاسع-عشر-كتاب-للدكتور-ابراهيم-شاكر&q;,&q;excerpt&q;:&q;في لحظة تاريخية تتّسم بانقضاء حقبات وتحوّلات عميقة في المنطقة، حيث يُعاد طرح الأسئلة الكبرى حول الهوية والكيان والمصير، تبرز الحاجة الملحّة إلى العودة إلى الجذور لفهم الحاضر واستشراف المستقبل. من هنا، تكتسب قراءة هذا الكتاب اليوم ضرورة تتجاوز الاهتمام الأكاديمي، لتصبح مدخلاً أساسياً لفهم ما نعيشه.&q;,&q;category&q;:{&q;id&q;:78,&q;name&q;:&q;ثقافة وتراث&q;,&q;color&q;:&q;#53e4ee&q;,&q;url&q;:&q;ثقافة-وتراث&q;},&q;gallery&q;:[],&q;video_type&q;:null,&q;uploaded_video&q;:null,&q;embedded_video&q;:null,&q;classifications&q;:[],&q;author&q;:null,&q;source&q;:{&q;id&q;:3182,&q;name&q;:&q;دار النهار&q;,&q;color&q;:null,&q;url&q;:&q;-دار-النهار&q;},&q;tags&q;:[{&q;id&q;:750,&q;name&q;:&q;ثقافة&q;,&q;url&q;:&q;ثقافة&q;},{&q;id&q;:20115,&q;name&q;:&q;يوسف بك كرم&q;,&q;url&q;:&q;-يوسف-بك-كرم-&q;}],&q;date&q;:&q;2026-04-23 09:53:01&q;,&q;featured_images&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/Divers/e3b8e7e2-58d0-4499-a58c-bf0f5365c579.jpg&q;,&q;sort_order&q;:0}]}]},{&q;type&q;:&q;category&q;,&q;label&q;:null,&q;link&q;:null,&q;haveSubMenu&q;:true,&q;item&q;:{&q;id&q;:22,&q;name&q;:&q;كتائبيات&q;,&q;url&q;:&q;كتائبيات&q;},&q;items&q;:[],&q;lastNews&q;:[{&q;title&q;:&q;إقليم الكتائب في البقاع الغربي وراشيا يستقبل وفدا من التقدمي: لتكريس منطق الدولة&q;,&q;sub_title&q;:null,&q;url&q;:&q;إقليم-الكتائب-في-البقاع-الغربي-وراشيا-يستقبل-وفدا-من-التقدمي-لتكزيس-منطق-الدولة&q;,&q;excerpt&q;:&q;زار وفد من الحزب التقدمي الاشتراكي ضمّ وكيل داخلية البقاع الغربي كمال حندوس، ووكيل داخلية البقاع الجنوبي عارف أبو منصور، إلى جانب أعضاء من وكالتي الداخلية ومعتمدين، مقر إقليم البقاع الغربي وراشيا الكتائبي في بلدة خربة قنفار، حيث كان في استقبالهم رئيسة الإقليم غيتا العجيل، وعدد من كوادر حزب الكتائب اللبنانية في المنطقة.&q;,&q;category&q;:{&q;id&q;:22,&q;name&q;:&q;كتائبيات&q;,&q;color&q;:&q;#006633&q;,&q;url&q;:&q;كتائبيات&q;},&q;gallery&q;:[{&q;id&q;:null,&q;image&q;:&q;new-website/Kataebiyet/visit takadome bekaa/WhatsApp Image 2026-05-18 at 10.14.13 AM (1).jpeg&q;,&q;sort_order&q;:0},{&q;id&q;:null,&q;image&q;:&q;new-website/Kataebiyet/visit takadome bekaa/WhatsApp Image 2026-05-18 at 10.14.13 AM.jpeg&q;,&q;sort_order&q;:1},{&q;id&q;:null,&q;image&q;:&q;new-website/Kataebiyet/visit takadome bekaa/WhatsApp Image 2026-05-18 at 10.14.14 AM (1).jpeg&q;,&q;sort_order&q;:2},{&q;id&q;:null,&q;image&q;:&q;new-website/Kataebiyet/visit takadome bekaa/WhatsApp Image 2026-05-18 at 10.14.14 AM (2).jpeg&q;,&q;sort_order&q;:3},{&q;id&q;:null,&q;image&q;:&q;new-website/Kataebiyet/visit takadome bekaa/WhatsApp Image 2026-05-18 at 10.14.14 AM.jpeg&q;,&q;sort_order&q;:4}],&q;video_type&q;:nul